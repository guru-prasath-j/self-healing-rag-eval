# ──────────────────────────────────────────────────────────
#  Self-Healing RAG Pipeline — Environment Variables
#  Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────────────────

# Required: Groq API key (get one free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the default Groq model
# GROQ_MODEL=llama3-8b-8192        # fast, free tier
# GROQ_MODEL=llama3-70b-8192       # more capable

# Optional: Number of documents to retrieve per query (default: 4)
# RETRIEVAL_K=4

# Optional: Maximum critique-reformulate cycles (default: 2)
# MAX_RETRIES=2

